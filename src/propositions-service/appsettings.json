{
  "ConnectionStrings": {
    "wf-propositions-postgresdb": "Host=localhost;Port=5432;Database=wf-propositions-postgresdb;Username=postgres;Password=postgres"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
      "WriteFluency.Propositions.DailyPropositionGenerator": "Warning"
    }
  },
  "AllowedClients": "https://writefluency.com,http://localhost:4200,http://localhost:4000",
  "ExternalApis": {
    "OpenAI": {
      "BaseAddress": "https://api.openai.com/",
      "ParagraphGenerationModel": "gpt-5.4-mini",
      "ArticleValidationModel": "gpt-5.4-nano-2026-03-17",
      "Routes": {
        "Completion": "v1/chat/completions",
        "Speech": "v1/audio/speech"
      },
      "Key": "{OPEN_AI_API_KEY}"
    },
    "TextToSpeech": {
      "Key": "{TEXT_TO_SPEECH_API_KEY}"
    },
    "News": {
      "BaseAddress": "https://api.thenewsapi.com/",
      "Routes": {
        "TopStories": "v1/news/top"
      },
      "AttemptTimeoutSeconds": 30,
      "TotalRequestTimeoutSeconds": 90,
      "Key": "{NEWS_API_KEY}"
    },
    "Cloudflare": {
      "BaseAddress": "https://api.cloudflare.com/client/v4/",
      "ZoneName": "writefluency.com",
      "AssetsBaseAddress": "https://minioapi.writefluency.com",
      "WarmupEnabled": true,
      "WarmupIntervalHours": 2,
      "WarmupRecentPropositionsLimit": 120,
      "WarmupConcurrency": 6,
      "WarmupTimeoutSeconds": 20,
      "PurgeUrls": [
        "https://writefluency.com/",
        "https://writefluency.com/exercises",
        "https://writefluency.com/sitemap.xml"
      ]
    }
  },
  "Propositions": {
    "DailyRequestsLimit": 20,
    "PropositionsLimitPerTopic": 30000,
    "NewsRequestLimit": 3,
    "CatalogAccessTeaser": {
      "Enabled": true,
      "AnonymousFingerprintSalt": "local-development-catalog-access-teaser-salt",
      "AnonymousSampleLifetimeLimit": 1,
      "FreeIntroLifetimeLimit": 1
    }
  },
  "TextComparison": {
    "RefinementValidation": {
      "MaxUserTextLength": 3000
    },
    "MistakePatternClassification": {
      "Enabled": true,
      "Model": "gpt-5.4-nano-2026-03-17",
      "MaxOutputTokens": 1200,
      "MaxComparisonsPerRequest": 10,
      "Temperature": 0.2,
      "ReasoningEffort": "low"
    },
    "AiUsage": {
      "Enabled": true,
      "DailySubmissionLimit": 40,
      "MonthlySubmissionLimit": 300,
      "MonthlyEstimatedCostLimitUsd": 0.50,
      "InputUsdPerMillionTokens": 0.05,
      "OutputUsdPerMillionTokens": 0.40
    },
    "ProReviewTeaser": {
      "Enabled": true,
      "AnonymousFingerprintSalt": "local-development-pro-review-teaser-salt",
      "AnonymousSampleLifetimeLimit": 1,
      "FreeIntroLifetimeLimit": 1,
      "FreeMonthlyLimit": 1,
      "PendingReviewExpiryMinutes": 15
    }
  },
  "RunNewsWorkerOnStartup": false,
  "FileStorage": {
    "Endpoint": "127.0.0.1:9000",
    "AccessKey": "admin",
    "SecretKey": "admin123"
  }
}
