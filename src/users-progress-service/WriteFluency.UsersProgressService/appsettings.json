{
  "Cosmos": {
    "Endpoint": "https://writefluencyusersprodcosmos.documents.azure.com/",
    "DatabaseName": "wf-users-progress",
    "ProgressContainer": "user_progress",
    "AttemptsContainer": "user_attempts",
    "Namespace": "local"
  },
  "SharedAuthCookie": {
    "Scheme": "Identity.Application",
    "CookieName": ".AspNetCore.Identity.Application"
  },
  "SharedDataProtection": {
    "ApplicationName": "WriteFluency.SharedAuth",
    "BlobUri": "",
    "KeyIdentifier": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200",
      "https://writefluency.com"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  }
}
