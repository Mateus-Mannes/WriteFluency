{
  "projectPath": ".",
  "inputPath": "./aspirate-output",
  "outputPath": "aspirate-output",
  "namespace": "writefluency",
  "containerRegistry": "ghcr.io",
  "containerImageTags": [
    "latest"
  ],
  "imagePullPolicy": "Always",
  "containerBuilder": "docker",
  "containerRepositoryPrefix": "Mateus-Mannes",
  "kubeContext": "minikube",
  "outputFormat": "kustomize",
  "parameters": [
    "wf-infra-minio-user=minioadmin",
    "wf-infra-minio-password=admin123",
    "wf-infra-postgres-password=postgres",
    "wf-infra-redis-password=admin123"
  ],
  "disableSecrets": true,
  "skipFinalKustomizeGeneration": false,
  "privateRegistryEmail": "aspir8@aka.ms",
  "includeDashboard": false,
  "useCustomNamespace": true,
  "processAllComponents": true
}